{
  "rules": {
    "analytics": {
      "vistas": {
        "$productId": {
          "count": {
            ".read": true,
            ".write": "!data.exists() || newData.val() == data.val() + 1",
            ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1000000"
          }
        }
      },
      "whatsapp": {
        "$productId": {
          "count": {
            ".read": true,
            ".write": "!data.exists() || newData.val() == data.val() + 1",
            ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1000000"
          }
        }
      },
      "busquedas": {
        "$termino": {
          ".read": true,
          ".write": "!data.exists() || newData.val() == data.val() + 1",
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 10000000"
        }
      },
      "visitas": {
        "count": {
          ".read": true,
          ".write": "!data.exists() || newData.val() == data.val() + 1",
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100000000"
        },
        "dias": {
          "$dia": {
            ".read": true,
            ".write": "!data.exists() || newData.val() == data.val() + 1",
            ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1000000"
          }
        }
      },
      ".read": true,
      ".write": false
    },
    "almacenes": {
      ".read": true,
      ".write": false,
      "$almId": {
        ".write": "!newData.exists() || !root.child('admin_auth/hash').exists() || newData.child('_proof').val() === root.child('admin_auth/hash').val()",
        ".validate": "newData.hasChildren(['nombre'])",
        "nombre": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length < 200" },
        "direccion": { ".validate": "newData.isString() && newData.val().length < 300" },
        "ubicacion": { ".validate": "newData.isString() && newData.val().length < 500" },
        "_proof": { ".validate": "newData.isString() && newData.val().length == 64" }
      }
    },
    "tokens": {
      "$tokenId": {
        ".read": false,
        ".write": true,
        ".validate": "newData.hasChildren(['token', 'timestamp']) && newData.child('timestamp').val() >= now - 900000 && newData.child('timestamp').val() <= now + 900000",
        "token": {
          ".validate": "newData.isString() && newData.val().length > 50 && newData.val().length < 500"
        },
        "timestamp": {
          ".validate": "newData.isNumber()"
        },
        "userAgent": {
          ".validate": "newData.isString()"
        },
        "fingerprint": {
          ".validate": "newData.isString()"
        },
        "deviceId": {
          ".validate": "newData.isString()"
        }
      },
      ".read": true,
      ".write": false
    },
    ".read": false,
    ".write": false,
    "errores_js": {
      ".read": true,
      ".write": false,
      "$errId": {
        ".write": "!data.exists()",
        ".validate": "newData.hasChildren(['mensaje','pagina','ts']) && newData.child('mensaje').isString() && newData.child('mensaje').val().length > 0 && newData.child('mensaje').val().length <= 300 && newData.child('pagina').isString() && newData.child('pagina').val().length <= 200 && newData.child('ts').isNumber() && newData.child('ts').val() >= now - 300000 && newData.child('ts').val() <= now + 60000",
        "mensaje": { ".validate": "newData.isString() && newData.val().length <= 300" },
        "pagina": { ".validate": "newData.isString() && newData.val().length <= 200" },
        "ts": { ".validate": "newData.isNumber()" },
        "ua": { ".validate": "newData.isString() && newData.val().length <= 200" },
        "stack": { ".validate": "newData.isString() && newData.val().length <= 500" }
      }
    },
    "auditoria_productos": {
      ".read": true,
      ".write": false,
      "$auditId": {
        ".write": "!data.exists()",
        ".validate": "newData.hasChildren(['accion','productoId','nombre','ts']) && newData.child('accion').isString() && newData.child('accion').val().length <= 20 && newData.child('productoId').isString() && newData.child('productoId').val().length <= 40 && newData.child('nombre').isString() && newData.child('nombre').val().length <= 80 && newData.child('ts').isNumber() && newData.child('ts').val() >= now - 300000 && newData.child('ts').val() <= now + 60000",
        "accion": { ".validate": "newData.isString() && newData.val().length <= 20" },
        "productoId": { ".validate": "newData.isString() && newData.val().length <= 40" },
        "nombre": { ".validate": "newData.isString() && newData.val().length <= 80" },
        "ts": { ".validate": "newData.isNumber()" },
        "campo": { ".validate": "newData.isString() && newData.val().length <= 20" },
        "de": { ".validate": "newData.isString() && newData.val().length <= 120" },
        "a": { ".validate": "newData.isString() && newData.val().length <= 120" }
      }
    },
    "avisos_stock": {
      "$productId": {
        "$tokenId": {
          ".write": true,
          ".validate": "newData.hasChildren(['token','ts'])",
          "token": {
            ".validate": "newData.isString() && newData.val().length >= 4 && newData.val().length < 500"
          },
          "ts": {
            ".validate": "newData.isNumber()"
          },
          "producto": {
            ".validate": "newData.isString() && newData.val().length < 200"
          },
          "tel": {
            ".validate": "newData.isString() && newData.val().length >= 6 && newData.val().length <= 25"
          }
        },
        ".read": true
      },
      ".read": true,
      ".write": false
    },
    "resenas": {
      ".read": true,
      ".write": false,
      "$productoId": {
        "$resenaId": {
          ".write": "!data.exists()",
          ".validate": "newData.hasChildren(['autor','texto','estrellas','fecha','ts']) && newData.child('estrellas').isNumber() && newData.child('estrellas').val() >= 1 && newData.child('estrellas').val() <= 5 && newData.child('texto').val().length >= 10 && newData.child('texto').val().length <= 400 && newData.child('autor').val().length >= 1 && newData.child('autor').val().length <= 50 && newData.child('ts').isNumber() && newData.child('ts').val() >= now - 300000 && newData.child('ts').val() <= now + 60000"
        }
      }
    },
    "pedidos": {
      ".read": true,
      ".write": false,
      "$pedidoId": {
        ".write": "!newData.exists() || !data.exists()",
        ".validate": "newData.hasChildren(['fecha','items','total','estado','actualizado']) && newData.child('fecha').isString() && newData.child('fecha').val().length <= 60 && newData.child('total').isNumber() && newData.child('total').val() >= 0 && newData.child('estado').isString() && newData.child('estado').val().length <= 20 && newData.child('actualizado').isNumber()",
        "id": { ".validate": "newData.isNumber() || newData.isString()" },
        "fecha": { ".validate": "newData.isString() && newData.val().length <= 60" },
        "estado": { ".validate": "newData.isString() && newData.val().length <= 20" },
        "total": { ".validate": "newData.isNumber() && newData.val() >= 0" },
        "actualizado": { ".validate": "newData.isNumber()" },
        "clienteTs": { ".validate": "newData.isNumber()" },
        "items": {
          "$idx": {
            "id": { ".validate": true },
            "nombre": { ".validate": "newData.isString() && newData.val().length <= 120" },
            "cantidad": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 10000" },
            "precio": { ".validate": "newData.isNumber() && newData.val() >= 0" }
          }
        }
      }
    },
    "ventas": {
      ".read": true,
      ".write": false,
      "$ventaId": {
        ".write": "!newData.exists() || !data.exists()",
        ".validate": "newData.hasChildren(['producto', 'precio', 'cantidad', 'total', 'fecha']) && newData.child('producto').isString() && newData.child('producto').val().length > 0 && newData.child('producto').val().length <= 200 && newData.child('precio').isNumber() && newData.child('precio').val() >= 0 && newData.child('cantidad').isNumber() && newData.child('cantidad').val() >= 0 && newData.child('total').isNumber() && newData.child('total').val() >= 0"
      }
    },
    "lista_espera": {
      ".read": "auth != null",
      ".write": false,
      "$productoId": {
        "$entradaId": {
          ".write": true,
          ".validate": "newData.hasChildren(['tel','productoId','ts']) && newData.child('tel').isString() && newData.child('tel').val().length >= 6 && newData.child('tel').val().length <= 25 && newData.child('ts').isNumber()"
        }
      }
    },
    "interesados": {
      ".read": true,
      ".write": false,
      "$productoId": {
        "$ts": {
          ".write": true,
          ".validate": "newData.hasChildren(['ts','producto','productoId']) && newData.child('ts').isNumber() && newData.child('ts').val() >= now - 300000 && newData.child('ts').val() <= now + 60000 && newData.child('producto').isString() && newData.child('producto').val().length <= 200"
        }
      }
    },
    "configuracion": {
      ".read": true,
      ".write": false,
      "categorias": {
        ".write": false
      },
      "version": {
        ".read": true,
        ".write": false
      }
    },
    "config": {
      "version": {
        ".read": true,
        ".write": "auth != null",
        ".validate": "newData.isNumber()"
      }
    },
    "admin_push_requests": {
      "$reqId": {
        ".write": "newData.child('proof').val() === root.child('admin_auth/hash').val()",
        ".validate": "newData.hasChildren(['title','body','ts','proof']) && newData.child('title').isString() && newData.child('title').val().length >= 1 && newData.child('title').val().length <= 100 && newData.child('body').isString() && newData.child('body').val().length >= 1 && newData.child('body').val().length <= 300 && newData.child('ts').isNumber()"
      },
      ".read": false,
      ".write": false
    },
    "admin_meta": {
      ".read": false,
      ".write": false,
      "pinHash": {
        ".write": "!data.exists()",
        ".validate": "newData.isString() && newData.val().length == 64"
      }
    },
    "admin_tokens": {
      "$tokenId": {
        ".write": "!newData.exists() || (root.child('admin_meta/pinHash').exists() && newData.child('proof').val() === root.child('admin_meta/pinHash').val())",
        ".validate": "newData.hasChildren(['token','ts','proof'])",
        "token": {
          ".validate": "newData.isString() && newData.val().length >= 4 && newData.val().length < 500"
        },
        "ts": {
          ".validate": "newData.isNumber()"
        },
        "proof": {
          ".validate": "newData.isString() && newData.val().length == 64"
        },
        "label": {
          ".validate": "newData.isString() && newData.val().length < 80"
        }
      },
      ".read": false,
      ".write": false
    },
    "avisos_count": {
      "$productId": {
        "count": {
          ".read": true,
          ".write": true,
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1000000"
        }
      },
      ".read": true,
      ".write": false
    },
    "admin_auth": {
      ".read": "auth != null",
      ".write": "!data.exists() || newData.child('proof').val() == data.child('hash').val()",
      ".validate": "newData.hasChildren(['hash','salt','iterations']) && newData.child('hash').isString() && newData.child('hash').val().length == 64 && newData.child('salt').isString() && newData.child('salt').val().length >= 20 && newData.child('iterations').isNumber() && newData.child('iterations').val() >= 100000"
    }
  }
}