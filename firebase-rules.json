{
  "rules": {
    "analytics": {
      "vistas": {
        "$productId": {
          "count": {
            ".read": true,
            ".write": true,
            ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1000000"
          }
        }
      },
      "whatsapp": {
        "$productId": {
          "count": {
            ".read": true,
            ".write": true,
            ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1000000"
          }
        }
      },
      ".read": true,
      ".write": false
    },
    "tokens": {
      "$tokenId": {
        ".read": false,
        ".write": true,
        ".validate": "newData.hasChildren(['token', 'timestamp']) && newData.child('timestamp').val() <= now + 60000",
        "token": {
          ".validate": "newData.isString() && newData.val().length > 50 && newData.val().length < 500"
        },
        "timestamp": {
          ".validate": "newData.isNumber()"
        },
        "userAgent": {
          ".validate": "newData.isString()"
        }
      },
      ".read": "auth != null",
      ".write": false
    },
    ".read": false,
    ".write": false,
    "avisos_stock": {
      "$productId": {
        "$tokenId": {
          ".write": true,
          ".validate": "newData.hasChildren(['token','timestamp']) && newData.child('timestamp').val() <= now + 60000",
          "token": {
            ".validate": "newData.isString() && newData.val().length > 50 && newData.val().length < 500"
          },
          "timestamp": {
            ".validate": "newData.isNumber()"
          }
        },
        ".read": "auth != null"
      },
      ".read": "auth != null",
      ".write": false
    },
    "ventas": {
      ".read": true,
      ".write": false,
      "$ventaId": {
        ".write": true,
        ".validate": "newData.hasChildren(['producto', 'precio', 'cantidad', 'total', 'fecha']) && newData.child('precio').isNumber() && newData.child('cantidad').isNumber() && newData.child('total').isNumber()"
      }
    },
    "avisos_count": {
      "$productId": {
        "count": {
          ".read": true,
          ".write": true,
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1000000"
        }
      },
      ".read": true,
      ".write": false
    }
  }
}